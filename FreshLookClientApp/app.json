{
  "expo": {
    "name": "FreshLook Client",
    "slug": "freshlook-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freshlookclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.freshlook.client",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.freshlook.client",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#C9A24D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "manifest": {
        "name": "FreshLook Client",
        "short_name": "FreshLook",
        "start_url": "/",
        "display": "standalone",
        "background_color": "#FAF8F4",
        "theme_color": "#C9A24D"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
