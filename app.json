{
  "expo": {
    "name": "My Fresh Look",
    "slug": "freshlook-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freshlookapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.freshlook.staff",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "My Fresh Look",
        "CFBundleName": "My Fresh Look",
        "NSPhotoLibraryUsageDescription": "My Fresh Look uses your photo library so you can choose and upload a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.freshlook.staff",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#C9A24D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "manifest": {
        "name": "My Fresh Look",
        "short_name": "My Fresh Look",
        "start_url": "/",
        "display": "standalone",
        "background_color": "#FAF8F4",
        "theme_color": "#C9A24D"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#C9A24D"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc17aa50-593c-4740-8bf4-6c62354c1290"
      }
    }
  }
}
